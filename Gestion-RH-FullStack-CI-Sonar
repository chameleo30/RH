pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        booleanParam(
            name: 'BLOCK_ON_QUALITY_GATE',
            defaultValue: false,
            description: 'Bloquer le pipeline si le Quality Gate SonarQube échoue'
        )
    }

    tools {
        nodejs 'NodeJS_20'
        maven 'Maven_3'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                    echo "===== OUTILS ====="
                    git --version
                    node --version
                    npm --version
                    java -version
                    mvn --version
                '''
            }
        }

        stage('Frontend - Install') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Frontend - Tests') {
            steps {
                dir('frontend') {
                    sh 'CI=true npm test -- --coverage --watchAll=false'
                    sh 'test -f coverage/lcov.info'
                }
            }
        }

        stage('Frontend - SonarQube') {
            steps {
                dir('frontend') {
                    script {
                        def scannerHome = tool 'SonarScanner'

                        withSonarQubeEnv('SonarQube') {
                            sh "${scannerHome}/bin/sonar-scanner"
                        }
                    }
                }
            }
        }

        stage('Frontend - Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    script {
                        def qualityGate = waitForQualityGate()

                        echo "Frontend Quality Gate : ${qualityGate.status}"

                        if (
                            params.BLOCK_ON_QUALITY_GATE &&
                            qualityGate.status != 'OK'
                        ) {
                            error("Quality Gate frontend échoué : ${qualityGate.status}")
                        }
                    }
                }
            }
        }

        stage('Frontend - Build') {
            steps {
                dir('frontend') {
                    sh 'CI=false npm run build'
                }
            }
        }

        stage('Backend - Tests, JaCoCo et SonarQube') {
            steps {
                dir('backend') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            mvn -B clean                                 org.jacoco:jacoco-maven-plugin:0.8.13:prepare-agent                                 verify                                 org.jacoco:jacoco-maven-plugin:0.8.13:report                                 org.sonarsource.scanner.maven:sonar-maven-plugin:sonar                                 -Dsonar.projectKey=gestion-rh-backend                                 -Dsonar.projectName="Gestion RH Backend"                                 -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        '''
                    }
                }
            }
        }

        stage('Backend - Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    script {
                        def qualityGate = waitForQualityGate()

                        echo "Backend Quality Gate : ${qualityGate.status}"

                        if (
                            params.BLOCK_ON_QUALITY_GATE &&
                            qualityGate.status != 'OK'
                        ) {
                            error("Quality Gate backend échoué : ${qualityGate.status}")
                        }
                    }
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts(
                    artifacts: 'frontend/build/**, backend/target/*.jar, frontend/coverage/lcov.info, backend/target/site/jacoco/jacoco.xml',
                    allowEmptyArchive: true,
                    fingerprint: true
                )
            }
        }
    }

    post {
        always {
            junit(
                testResults: 'backend/target/surefire-reports/*.xml',
                allowEmptyResults: true
            )
        }

        success {
            echo 'Pipeline terminé avec succès.'
        }

        failure {
            echo 'Pipeline en échec. Consultez le stage et les logs correspondants.'
        }
    }
}
